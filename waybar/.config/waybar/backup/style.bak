@import "./themes/rose-pine.css";


/* Global */
* {
  border: none;
  border-radius: 10px;
  background: transparent;
  font-family: "JetBrainsMono Nerd Font Propo";
  font-weight: bold;
  font-size: 14px;
}

window#waybar {
  background-color: transparent;
}


/* Module containers */

.modules-left,
.modules-center,
.modules-right {
  margin: 0.5em 0.5em;
}


/* --- General Modules --- */

#workspaces, #mode, #window,
#clock, #pulseaudio, #backlight, #idle_inhibitor,
#network, #bluetooth,
#cpu, #memory, #battery {
  margin: 1px;
  padding: 0px 10px;
  background-color: @base;
}


/* --- Left-side Modules --- */

/* Sway Workspace */
#workspaces {
  margin: 1px;
  padding: 0px;
  background-color: @base;
}

/* Workspace buttons */
#workspaces button {
  padding: 0px 8px;
  color: @muted;
  transition: all 0.2s ease;
}

/* Active workspace button */
#workspaces button.focused {
  margin: -1px -1px;
  padding: 0px 21px;
  color: @base;
  font-size: 21px;
  background-color: @rose;
}


/* Sway Modes */

#mode {
  border-radius: 0px;
  border-bottom: 3px solid;
  border-color: @foam;
  background-color: rgba(38, 35, 58, 0.15); /* overlay 15% opacity */
  /* background-color: rgba(246, 193, 119, 0.1); */
  color: @foam;
}


/* Sway Window */

#window {
  background-color: transparent;
}


/* --- Center Modules --- */

#clock {
  color: @gold;
}


/* --- Right-side Modules --- */

#idle_inhibitor.activated {
  color: @gold;
}
#idle_inhibitor.deactivated {
  color: @love;
}

#network {
  color: @foam;
}

#bluetooth {
  color: @foam;
}

#cpu {
  color: @love;
}

#memory {
  color: @gold;
}

#battery {
  color: @foam;
}

#battery.warning {
  color: @gold;
}

#battery.critical {
  color: @love;
}
